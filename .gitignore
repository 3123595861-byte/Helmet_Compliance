# ========================
# 1. Python 缓存与系统文件
# ========================
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.DS_Store
Thumbs.db

# ========================
# 2. 虚拟环境 (绝对不能传)
# ========================
venv/
env/
.env/

# ========================
# 3. 动态产生的数据与日志
# ========================
# 排除你代码中生成的违规截图和 CSV 日志
outputs/
# 排除用来存放测试视频或图片的本地数据集文件夹
data/

# ========================
# 4. AI 模型权重
# ========================
# 虽然 yolov8n.pt 不大，但最佳实践是不上传二进制模型权重
# 如果以后导出了 onnx 模型，也可以在此屏蔽
*.pt
*.onnx
*.engine

# ========================
# 5. 编辑器与本地配置
# ========================
# 避免把你的个人编辑器习惯推送到代码库
.cursor/
.vscode/
.idea/

# ========================
# 6. 敏感信息与环境变量
# ========================
# 以后如果用到 API Key 或数据库密码，通常写在 .env 里
.env
.env.local
*.log